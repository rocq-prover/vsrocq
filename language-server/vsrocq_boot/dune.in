(library
 (name vsrocqtop_boot)
 (public_name vsrocq-language-server.vsrocqtop_boot)
 (wrapped false)
 (modules args vsrocqSettings vsrocqBoot)
 (preprocess (pps ppx_optcomp -- -cookie "ppx_optcomp.env=env ~rocq:(Defined \"@@ROCQVERSION@@\")"))
 (preprocessor_deps vsrocq_config.mlh)
 (libraries @@ROCQ_RUNTIME@@.sysinit dm))


(rule
  (target vsrocq_config.mlh)
  (mode (promote (only vsrocq_config.mlh)))
  (action (with-stdout-to %{target}
    (progn
      (echo "(* Automatically generated, don't edit *)\n")
      (echo "[%%define lsp ")
      (run vsrocq_version_parser %{version:lsp})
      (echo "]\n")))))