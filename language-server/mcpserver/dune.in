(library
 (name mcpserver)
 (public_name vsrocq-language-server.mcp)
 (modules mcpBase mcpManager mcpPrinting vsrocqTools)
 (libraries yojson @@ROCQ_RUNTIME@@.sysinit @@ROCQ_RUNTIME@@.vernac lsp sel dm protocol vsrocqtop_boot)
 (preprocessor_deps vsrocq_config.mlh)
 (preprocess (pps ppx_import ppx_sexp_conv ppx_yojson_conv ppx_optcomp -- -cookie "ppx_optcomp.env=env ~rocq:(Defined \"%{coq:version.major}.%{coq:version.minor}\")")))

(executable
 (name vsrocqmcp)
 (public_name vsrocqmcp)
 (modules vsrocqmcp)
 (flags -linkall)
 (package vsrocq-mcp-server)
 (preprocess (pps ppx_optcomp -- -cookie "ppx_optcomp.env=env ~rocq:(Defined \"@@ROCQVERSION@@\")"))
 (preprocessor_deps vsrocq_config.mlh)
 (libraries @@ROCQ_RUNTIME@@.sysinit @@ROCQ_RUNTIME@@.tactics sel yojson dm lsp mcpserver vsrocqtop_boot))

(rule
  (target vsrocq_config.mlh)
  (mode (promote (only vsrocq_config.mlh)))
  (action (with-stdout-to %{target}
    (progn
      (echo "(* Automatically generated, don't edit *)\n")
      (echo "[%%define lsp ")
      (run vsrocq_version_parser %{version:lsp})
      (echo "]\n")))))